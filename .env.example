# TATKO PI Envanter — ortam değişkenleri şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ── Veritabanı ─────────────────────────────────────────────
POSTGRES_DB=tatko_pi
POSTGRES_USER=tatko
POSTGRES_PASSWORD=GUCLU_BIR_SIFRE_GIRIN

# ── JWT gizli anahtarı ──────────────────────────────────────
# Rastgele 32+ karakter: openssl rand -hex 32
SECRET_KEY=BURAYA_GIZLI_ANAHTAR_GIRIN

# ── E-posta (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=pi@supertakimlar.com
EMAIL_FROM_NAME=TATKO PI Envanter

# ── Frontend URL (e-postalardaki form linkleri için) ────────
FRONTEND_URL=https://supertakimlar.com/pi4

# ── CORS ────────────────────────────────────────────────────
# Virgülle ayrılmış izin verilen origin'ler
CORS_ORIGINS=https://supertakimlar.com
