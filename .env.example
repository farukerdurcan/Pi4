# TATKO PI Envanter — ortam değişkenleri şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ── Veritabanı ─────────────────────────────────────────────
POSTGRES_DB=tatko_pi
POSTGRES_USER=tatko
POSTGRES_PASSWORD=GUCLU_BIR_SIFRE_GIRIN

# ── JWT gizli anahtarı ──────────────────────────────────────
# Rastgele 32+ karakter: openssl rand -hex 32
# Tanımlı değilse uygulama başlamaz (fail-fast)
SECRET_KEY=BURAYA_GIZLI_ANAHTAR_GIRIN

# ── Super admin hesabı (ilk kurulumda bir kez oluşturulur) ──
# Tanımlı değilse super admin seed hesabı oluşturulmaz
SUPER_ADMIN_EMAIL=admin@firmaniz.com
SUPER_ADMIN_SIFRE=GUCLU_BIR_SIFRE_GIRIN
SUPER_ADMIN_AD=Admin
SUPER_ADMIN_SOYAD=Kullanici

# ── İlk IK hesabı (opsiyonel, ilk kurulumda bir kez oluşturulur) ──
IK_EMAIL=ik@firmaniz.com
IK_BASLANGIC_SIFRE=GUCLU_BIR_SIFRE_GIRIN

# ── E-posta (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=pi@supertakimlar.com
EMAIL_FROM_NAME=TATKO PI Envanter

# ── Frontend URL (e-postalardaki form linkleri için) ────────
FRONTEND_URL=https://supertakimlar.com/pi4

# ── Swagger Docs (geliştirmede true, production'da false) ───
DOCS_ENABLED=false

# ── CORS ────────────────────────────────────────────────────
# Virgülle ayrılmış izin verilen origin'ler
CORS_ORIGINS=https://supertakimlar.com
